<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MMLaunch"
        x:Class="MMLaunch.ConfirmDialog"
        x:DataType="vm:ConfirmDialogViewModel"
        Title="Confirm"
        Width="500" Height="316"
        CanResize="False">
    <DockPanel Margin="10" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <Button Content="OK" Command="{Binding Confirm}" Width="100" />
            <Button Content="Cancel" Command="{Binding Cancel}" Width="100" />
        </StackPanel>
        <CheckBox DockPanel.Dock="Bottom"
                  Content="{Binding CheckBoxText}"
                  IsVisible="{Binding CheckBoxVisible}"
                  IsChecked="{Binding CheckboxChecked, Mode=TwoWay}"
                  Margin="0,4,0,0" />
        <ScrollViewer>
            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
        </ScrollViewer>
    </DockPanel>
</Window>
